{
  "ConnectionStrings": {
    "Postgres": "__POSTGRES_CONNECTION_STRING__"
  },
  "Storage": {
    "RootPath": "/data/resources"
  },
  "InternalApi": {
    "Key": "__INTERNAL_API_KEY__"
  },
  "ApiKeys": {
    "HashPepper": "__API_KEYS_HASH_PEPPER__"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
